# PDFForge Backend – Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Comma-separated list of allowed frontend origins
# Use * to allow all (not recommended for production)
ALLOWED_ORIGINS=http://localhost:5500,https://yourdomain.com

# Optional: override uploads directory path
# UPLOADS_DIR=/var/data/pdfforge/uploads
